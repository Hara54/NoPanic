<?xml version="1.0" encoding="utf-8"?>
<configuration>
    <configSections>
        <sectionGroup name="userSettings" type="System.Configuration.UserSettingsGroup, System, Version=4.0.0.0, Culture=neutral, PublicKeyToken=b77a5c561934e089" >
            <section name="NoPanic.Properties.Settings" type="System.Configuration.ClientSettingsSection, System, Version=4.0.0.0, Culture=neutral, PublicKeyToken=b77a5c561934e089" allowExeDefinition="MachineToLocalUser" requirePermission="false" />
        </sectionGroup>
    </configSections>
    <startup> 
    <supportedRuntime version="v4.0" sku=".NETFramework,Version=v4.5"/></startup>
    <userSettings>
        <NoPanic.Properties.Settings>
            <setting name="Veille_Desactive" serializeAs="String">
                <value>False</value>
            </setting>
            <setting name="InterfaceFilter_IP" serializeAs="String">
                <value />
            </setting>  
            <setting name="Port_Ecoute" serializeAs="String">
                <value>1500</value>
            </setting>
            <setting name="Port_Envoi" serializeAs="String">
                <value>1501</value>
            </setting>
            <setting name="TestPresence_Frequence" serializeAs="String">
                <value>60</value>
            </setting>
            <setting name="TestPresence_IP" serializeAs="String">
                <value>255.255.255.255</value>
            </setting>
            <setting name="Alerte_IP" serializeAs="String">
                <value>255.255.255.255</value>
            </setting>
            <setting name="Alerte_Touche" serializeAs="String">
                <value>2</value>
            </setting>
            <setting name="Alerte_Son" serializeAs="String">
                <value>True</value>
            </setting>
            <setting name="Alerte_Titre" serializeAs="String">
                <value>ALERTE AGRESSION</value>
            </setting>
            <setting name="Alerte_Message" serializeAs="String">
                <value>%NOM%</value>
            </setting>
            <setting name="Alerte_Confirmation" serializeAs="String">
                <value>Message reçu par vos collègues</value>
            </setting>
            <setting name="Erreur_Message" serializeAs="String">
                <value>Ce message apparait si vous avez un problème de communication ou qu'aucun autre client NoPanic n'est présent sur le réseau.</value>
            </setting>
            <setting name="Quitter_Titre" serializeAs="String">
                <value>Confirmation</value>
            </setting>
            <setting name="Quitter_Message" serializeAs="String">
                <value>Est-vous sûr de vouloir quitter l'application NoPanic ?</value>
            </setting>
        </NoPanic.Properties.Settings>
    </userSettings>
</configuration>
